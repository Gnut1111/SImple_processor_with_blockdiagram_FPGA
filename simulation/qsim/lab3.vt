	INPUT_DA[0] = 1'b1;
	INPUT_DA[0] = #70000 1'b0;
end 

PROCESSORREAL_vlg_sample_tst tb_sample (
	.CLK(CLK),
	.INPUT_CON(INPUT_CON),
	.INPUT_DA(INPUT_DA),
	.sampler_tx(sampler)
);

PROCESSORREAL_vlg_check_tst tb_out(
	.ALU_O(ALU_O),
	.OUT(OUT),
	.PC_O(PC_O),
	.sampler_rx(sampler)
);
endmodule

