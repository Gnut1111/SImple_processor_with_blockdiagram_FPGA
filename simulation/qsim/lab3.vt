// port map - connection between master ports and signals/registers   
	.ALU_O(ALU_O),
	.CLK(CLK),
	.INPUT_CON(INPUT_CON),
	.INPUT_DA(INPUT_DA),
	.OUT(OUT),
	.PC_O(PC_O)
);

