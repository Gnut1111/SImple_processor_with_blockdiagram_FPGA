// constants                                           
// general purpose registers
reg CLK;
reg [15:0] INPUT_CON;
reg [3:0] INPUT_DA;
// wires                                               
wire [15:0] ALU_O;
wire [15:0] OUT;
wire [15:0] PC_O;

wire sampler;                             

// assign statements (if any)                          
